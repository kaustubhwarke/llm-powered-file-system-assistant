# =============================================================================
# LLM File Assistant - Environment Configuration
# Copy to .env and fill in your values. NEVER commit .env to source control.
# =============================================================================

# ---- LLM Provider Selection ----
# Choose: "openai" or "anthropic"
LLM_PROVIDER=openai

# ---- OpenAI ----
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ---- Anthropic ----
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-5

# ---- Filesystem Sandbox ----
# Absolute path. All FS operations are restricted to this root for security.
# Defaults to ./data if unset.
FS_ROOT=./data

# Max bytes a single file is allowed to be when read (default 25 MB)
FS_MAX_FILE_BYTES=26214400

# ---- Logging ----
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ---- Agent Behavior ----
# Maximum iterations of the tool-use loop before the agent gives up
AGENT_MAX_ITERATIONS=10
